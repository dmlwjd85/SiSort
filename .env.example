# ---------------------------------------------------------------------------
# API 키는 프로젝트 루트의 다른 저장소에 이미 있다면 그쪽의 값을 그대로 쓰면 됩니다.
# 예: c:\Project\All-in-One-Home\.env (또는 동일 Firebase 프로젝트를 쓰는 앱의 .env)
# 에 있는 VITE_FIREBASE_API_KEY, VITE_FIREBASE_AUTH_DOMAIN, … 항목을 복사해 아래에 붙이세요.
# ---------------------------------------------------------------------------
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# 쉼표로 구분 — 해당 이메일로 로그인 시 마스터(기록 열람 + 회원별 팩 추가 해제) — Firestore admins 없이도 가능
VITE_ADMIN_EMAILS=

# 회원 로그인: 이름(실명)+숫자 4자리만(생년월일 입력 없음). Firestore users 에 displayName+ birthDate 가
# 정의정 / 19851125 인 계정은 코드상 마스터 권한이 자동 부여됩니다(birthDate 는 구 가입·콘솔에서 설정 가능).

# Firestore 컬렉션 admins 문서 ID = 해당 계정 uid. 필드 예시:
#   { "master": true }  → 마스터(전 권한)
#   { "viewRecords": true }  → 회원 기록·팩 진행만 열람
#   { "unlockMembers": true }  → users.packUnlockBonus 만 편집(잠금 해제만)
#   {} 빈 문서 → 레거시: 마스터와 동일

# auth/operation-not-allowed 가 나오면:
# 1) Firebase 콘솔 → 프로젝트가 위 키와 일치하는지 확인
# 2) Authentication → Sign-in method → 이메일/비밀번호 사용 설정(켜기)
