rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 익명 로그인 후에만 쓰기 허용 (클라이언트에서 ensureFirebaseAuth 호출)
    match /rooms/{roomId} {
      allow read: if true;
      allow write: if request.auth != null;
      match /actions/{actionId} {
        allow read: if true;
        allow write: if request.auth != null;
      }
    }
  }
}
