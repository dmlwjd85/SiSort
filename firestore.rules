rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 데모용: 배포 전 반드시 인증·검증 규칙으로 강화하세요.
    match /rooms/{roomId} {
      allow read: if true;
      allow write: if true;
      match /actions/{actionId} {
        allow read, write: if true;
      }
    }
  }
}
