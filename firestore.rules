rules_version = '2';

/**
 * 배포: Firebase 콘솔 → Firestore → 규칙에 붙여 넣기
 * 관리자: `admins/{uid}` 문서
 * - 필드 없음(레거시 {}) → 마스터와 동일(기록 열람 + 회원별 packUnlockBonus)
 * - master: true → 위와 동일
 * - viewRecords: true → users 목록·기록 열람
 * - unlockMembers: true → 타인 users 문서의 packUnlockBonus 만 갱신 가능
 */
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function adminDoc() {
      return get(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function adminExists() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function adminLegacyFull() {
      return adminExists() && adminDoc().data.keys().size() == 0;
    }

    function adminMasterOrLegacy() {
      return adminExists()
        && (adminDoc().data.master == true || adminLegacyFull());
    }

    function adminHasViewRecords() {
      return adminExists()
        && (adminMasterOrLegacy() || adminDoc().data.viewRecords == true);
    }

    function adminCanUnlockOthers() {
      return adminExists()
        && (adminMasterOrLegacy() || adminDoc().data.unlockMembers == true);
    }

    function adminCanReadUsers() {
      return adminHasViewRecords() || adminCanUnlockOthers();
    }

    /** 마스터 이메일(master_6~7자리@sisort.local) — Authentication 토큰으로 식별(admins 문서 없이도 동일) */
    function isMasterAccountEmailAuth() {
      return isSignedIn()
        && request.auth.token.email is string
        && request.auth.token.email.matches('^master_[0-9]{6,7}@sisort\\.local$');
    }

    /** 마스터만 타인 users 삭제·차단 문서 쓰기 */
    function adminCanBanOrDeleteUsers() {
      return adminMasterOrLegacy() || isMasterAccountEmailAuth();
    }

    function packUnlockBonusUpdateOnly() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['packUnlockBonus'])
        && request.resource.data.packUnlockBonus is list
        && request.resource.data.packUnlockBonus.size() <= 32;
    }

    /** 팩별 사용자 최대 클리어 레벨(명예의 전당 쓰기 검증용) */
    function userPackLevel(uid, pk) {
      let u = get(/databases/$(database)/documents/users/$(uid));
      return u.data.packProgress != null && u.data.packProgress[pk] is int
        ? int(u.data.packProgress[pk])
        : 0;
    }

    function hallOfFameWriteValid(packKey) {
      return isSignedIn()
        && request.resource.data.keys().hasAll(['maxLevel', 'holderName', 'holderUid'])
        && request.resource.data.holderUid == request.auth.uid
        && request.resource.data.maxLevel is int
        && request.resource.data.maxLevel >= 1
        && request.resource.data.maxLevel <= 32
        && request.resource.data.holderName is string
        && request.resource.data.holderName.size() <= 48
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && userPackLevel(request.auth.uid, packKey) >= request.resource.data.maxLevel
        && (
          !resource.exists
          || (
            request.resource.data.maxLevel >= resource.data.maxLevel
            && (
              request.resource.data.maxLevel > resource.data.maxLevel
              || resource.data.holderUid == request.auth.uid
            )
          )
        );
    }

    /** 명예의 전당: 팩별 최고 레벨·달성자 표시명(누구나 읽기, 본인 진행도에 맞는 기록만 쓰기) */
    match /hallOfFame/{packKey} {
      allow read: if true;
      allow create, update: if hallOfFameWriteValid(packKey);
      allow delete: if false;
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || adminCanReadUsers();
      allow create: if isOwner(userId);
      /* purchasedPackKeys: 인앱 해금(클라이언트 직접 쓰기는 테스트용 — 운영 시 검증 서버에서만 갱신 권장) */
      allow update: if isOwner(userId)
        || (adminCanUnlockOthers() && packUnlockBonusUpdateOnly());
      /* 본인 계정 삭제(앱스토어 계정 삭제 요건) + 마스터의 타인 삭제 */
      allow delete: if isOwner(userId)
        || (adminCanBanOrDeleteUsers() && request.auth.uid != userId);
    }

    match /bannedUsers/{uid} {
      allow read: if isSignedIn() && request.auth.uid == uid;
      allow create, update, delete: if adminCanBanOrDeleteUsers();
    }

    match /admins/{adminId} {
      allow read: if isOwner(adminId);
      allow write: if false;
    }

    match /rooms/{roomId} {
      allow read, create, update: if isSignedIn();
      allow delete: if false;
    }

    match /rooms/{roomId}/actions/{actionId} {
      allow read, create, delete: if isSignedIn();
    }
  }
}
